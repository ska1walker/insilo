# ============================================================================
# insilo — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env to git.
# ============================================================================

# ---- Supabase (self-hosted, local) -----------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<set after running `supabase start`>
SUPABASE_SERVICE_ROLE_KEY=<set after running `supabase start`>

# ---- Backend ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development  # development | production
LOG_LEVEL=info

# ---- Redis (for Celery) ----------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- AI Services -----------------------------------------------------------
WHISPER_URL=http://localhost:8001
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda           # cuda | cpu
WHISPER_COMPUTE_TYPE=float16  # float16 | int8

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

EMBEDDINGS_URL=http://localhost:8002
EMBEDDINGS_MODEL=BAAI/bge-m3

# ---- Storage ---------------------------------------------------------------
STORAGE_BUCKET_AUDIO=audio
STORAGE_MAX_UPLOAD_MB=500

# ---- Security --------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
SESSION_SECRET=<generate with: openssl rand -hex 32>

# ---- Frontend --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same as SUPABASE_ANON_KEY above>
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Optional: Telemetry (DEFAULT: NONE) -----------------------------------
# In line with the project's data sovereignty promise, no telemetry is
# enabled by default. Do not add Sentry, PostHog, or similar without
# explicit customer consent and self-hosted endpoints.
