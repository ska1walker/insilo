# ============================================================================
# Insilo - Umgebungsvariablen
# ============================================================================
# Lokale Dev-Umgebung. Im Olares-Deployment werden diese Werte automatisch
# über Helm-Values aus den System-Middlewares injiziert (siehe olares/values.yaml).
# ============================================================================

# ---- Datenbank (Olares-System-Postgres / lokal Docker-Compose) -------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insilo
DB_USER=insilo
DB_PASSWORD=insilo_dev_only

# ---- Redis / KVRocks --------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_NAMESPACE=insilo

# ---- Object Storage (Olares-System-MinIO / lokal Docker-Compose) -----------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=insilo_dev
MINIO_SECRET_KEY=insilo_dev_secret
MINIO_BUCKET=insilo-audio
MINIO_USE_SSL=false

# ---- Interne KI-Services ---------------------------------------------------
# Lokal: Service auf localhost oder via docker-compose
# Olares: Kubernetes-DNS (z.B. http://insilo-whisper:8001)
WHISPER_URL=http://localhost:8001
OLLAMA_URL=http://localhost:11434
EMBEDDINGS_URL=http://localhost:8002

# ---- Storage-Pfade ---------------------------------------------------------
# Lokal: relative Pfade
# Olares: /app/data und /app/cache werden gemountet
APP_DATA_DIR=./data
APP_CACHE_DIR=./cache

# ---- App-Konfiguration -----------------------------------------------------
APP_LANG=de
APP_TIMEZONE=Europe/Berlin
AUDIO_RETENTION_DAYS=90
MAX_UPLOAD_MB=500

# ---- Olares-Kontext (lokal mit Dev-Werten überschreiben) -------------------
OLARES_USER=devuser
OLARES_ZONE=devuser.olares.local

# ---- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USER=devuser

# ---- Entwicklung -----------------------------------------------------------
LOG_LEVEL=info
DEBUG=true
